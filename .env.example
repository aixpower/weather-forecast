# QWeather API Configuration
# Copy this file to .env and fill in your actual API credentials

# Your QWeather API Key (required)
# Get your API key from https://dev.qweather.com/
QWEATHER_API_KEY=your_api_key_here

# Your QWeather API Host  (required)
# Get a custom host from https://dev.qweather.com/
QWEATHER_API_HOST=your_custom_host_here
